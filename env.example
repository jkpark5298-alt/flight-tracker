<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Air Incheon Tracker</title>
    <style>
        body { font-family: -apple-system, sans-serif; background: #f4f4f9; margin: 0; padding: 15px; }
        .card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 15px; }
        h2 { margin-top: 0; font-size: 1.1rem; color: #333; }
        .label { font-size: 0.85rem; color: #666; font-weight: bold; margin-bottom: 5px; display: block; }
        input[type="text"] { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 16px; }
        .file-btn { background: #eef2ff; border: 1px dashed #4f46e5; color: #4f46e5; padding: 15px; text-align: center; border-radius: 8px; margin-bottom: 20px; cursor: pointer; }
        button[name="action"] { width: 100%; padding: 15px; background: #4f46e5; color: white; border: none; border-radius: 8px; font-weight: bold; font-size: 16px; }
        .result-box { border-top: 1px solid #eee; padding-top: 15px; }
        .data-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem; }
        .error { color: #d32f2f; background: #ffebee; padding: 10px; border-radius: 6px; font-size: 0.85rem; margin-bottom: 15px; }
    </style>
</head>
<body>
    <div class="card">
        <h2>항공 보안/안전 추적기</h2>
        <form method="post" enctype="multipart/form-data">
            <span class="label">1. 이미지 인식 (카메라)</span>
            <input type="file" name="file" accept="image/*" capture="environment" onchange="this.form.submit()" style="margin-bottom: 20px;">
            
            <span class="label">2. 인식 데이터 확인 및 수정</span>
            <input type="text" name="flight_number" placeholder="편명 입력 (예: KE101)" value="{{ flight_no }}">
            <input type="text" name="gate_info" placeholder="주기장/스팟 정보" value="{{ gate_info }}">
            
            <button type="submit" name="action" value="search">실시간 데이터 조회</button>
        </form>
    </div>

    {% if error %}
    <div class="error">{{ error }}</div>
    {% endif %}

    {% if flight %}
    <div class="card result-box">
        <h3 style="margin: 0 0 15px 0; font-size: 1rem; color: #4f46e5;">{{ flight.number }} 실시간 정보</h3>
        <div class="data_row" style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span style="color:#666">기종</span> <span>{{ flight.aircraft_code }}</span>
        </div>
        <div class="data_row" style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span style="color:#666">노선</span> <span>{{ flight.origin_airport_iata }} → {{ flight.destination_airport_iata }}</span>
        </div>
        <div class="data_row" style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span style="color:#666">현재 고도</span> <span>{{ flight.altitude }} ft</span>
        </div>
        <div class="data_row" style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span style="color:#666">지면 속도</span> <span>{{ flight.ground_speed }} kt</span>
        </div>
        <div class="data_row" style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span style="color:#666">점검 주기장</span> <span>{{ gate_info }}</span>
        </div>
    </div>
    {% endif %}
</body>
</html>